# GitHub API token used for full-account scans.
# For a large account like Sunwood-ai-labs, a token is effectively required.
GITHUB_TOKEN=ghp_your_token_here

# Optional alternative if you prefer to use GH_TOKEN instead.
# GH_TOKEN=ghp_your_token_here

# Preferred: GitHub App webhook mode.
# Webhook secret from the GitHub App settings page.
# GITHUB_APP_WEBHOOK_SECRET=replace_with_webhook_secret
# Optional: enable GitHub release reaction stamping in the Worker runtime.
# GITHUB_APP_ID=3157685
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_RELEASE_REACTION=eyes
# WORKER_LOG_LEVEL=debug
# GITHUB_APP_WEBHOOK_HOST=127.0.0.1
# GITHUB_APP_WEBHOOK_PORT=8787
# GITHUB_APP_WEBHOOK_PATH=/github/webhook

# Optional: Discord Incoming Webhook for change notifications.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Preferred: Discord Bot API configuration.
# The bot posts a short parent message, creates a thread for each notification,
# and sends the detailed Japanese embed inside that thread.
# DISCORD_BOT_TOKEN=your_discord_bot_token
# DISCORD_CHANNEL_ID can be either a raw channel ID (123456789012345678) or a channel URL:
# https://discord.com/channels/<guild_id>/<channel_id>
# DISCORD_CHANNEL_ID=123456789012345678
# Optional profiles:
# DISCORD_PROFILE=production
# DISCORD_PRODUCTION_CHANNEL_ID=123456789012345678
# DISCORD_TEST_CHANNEL_ID=123456789012345678
# DISCORD_PRODUCTION_MENTION_USER_ID=123456789012345678
# DISCORD_TEST_MENTION_USER_ID=123456789012345678
# Test notifications do not inherit production mentions unless DISCORD_TEST_MENTION_USER_ID is explicitly set.

# Optional: Set to true/1/yes/on to send notifications only when new releases are detected.
# DISCORD_NOTIFY_RELEASES_ONLY=true
# DISCORD_EXPLAINER_USER_ID=123456789012345678
