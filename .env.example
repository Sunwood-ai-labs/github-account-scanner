# GitHub API token used for full-account scans.
# For a large account like Sunwood-ai-labs, a token is effectively required.
GITHUB_TOKEN=ghp_your_token_here

# Optional alternative if you prefer to use GH_TOKEN instead.
# GH_TOKEN=ghp_your_token_here

# Optional: Discord Incoming Webhook for change notifications.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Preferred: Discord Bot API configuration.
# The bot posts a short parent message, creates a thread for each notification,
# and sends the detailed Japanese embed inside that thread.
# DISCORD_BOT_TOKEN=your_discord_bot_token
# DISCORD_CHANNEL_ID=123456789012345678
