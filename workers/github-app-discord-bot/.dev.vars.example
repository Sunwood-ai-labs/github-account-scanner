GITHUB_APP_WEBHOOK_SECRET=replace-with-webhook-secret
GITHUB_APP_WEBHOOK_PATH=/webhook
WORKER_LOG_LEVEL=debug

DISCORD_DELIVERY_PROFILE=test
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_CHANNEL_ID=https://discord.com/channels/<guild_id>/<channel_id>

# Optional GitHub release reaction stamping.
# GITHUB_APP_ID=3157685
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_RELEASE_REACTION=eyes

# Optional per-profile overrides.
# DISCORD_TEST_CHANNEL_ID=https://discord.com/channels/<guild_id>/<channel_id>
# DISCORD_PRODUCTION_CHANNEL_ID=https://discord.com/channels/<guild_id>/<channel_id>
# DISCORD_PRODUCTION_MENTION_USER_ID=123456789012345678
# DISCORD_TEST_MENTION_USER_ID=123456789012345678

# Optional toggles.
# DRY_RUN_DISCORD=true
# DRY_RUN_GITHUB_REACTION=true
# INCLUDE_PRERELEASES=true
# WEBHOOK_STATE_TTL_SECONDS=2592000
